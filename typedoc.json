{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs",
  "tsconfig": "tsconfig.json",
  "plugin": ["typedoc-github-theme"],
  "theme": "typedoc-github-theme",
  "name": "@gks101/numtowords",
  "includeVersion": true,
  "readme": "README.md",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "githubPages": true,
  "cleanOutputDir": true
}
