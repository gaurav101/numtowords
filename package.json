{
  "name": "@gks101/numtowords",
  "version": "1.0.2",
  "description": "Convert numbers to words in multiple languages and numeral systems (English, Indian, etc.)",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "types": "dist/types/index.d.ts",
  "homepage": "https://gaurav101.github.io/numtowords/",
  "repository": {
    "type": "git",
    "url": "https://github.com/gaurav101/numtowords.git"
  },
  "bugs": {
    "url": "https://github.com/gaurav101/numtowords/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && rollup -c rollup.config.mjs && tsc --target ES2020 --module ES2020 --downlevelIteration --skipLibCheck --noEmitOnError false --outDir dist --rootDir src src/locales/*.ts",
    "test": "jest",
    "lint": "tsc --noEmit",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:docs": "typedoc --theme typedoc-github-theme src/index.ts"
  },
  "keywords": [
    "number-to-words",
    "multilingual",
    "indian-numbering",
    "english-numbering",
    "hindi-numbering",
    "number-converter",
    "number-to-word-converter",
    "i18n",
    "numtowords",
    "number-converter",
    "amount-to-words",
    "numbers-to-text",
    "currency-formatter",
    "intl-number-format"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "rollup": "^4.18.0",
    "rollup-plugin-dts": "^6.1.1",
    "ts-jest": "^29.2.2",
    "tslib": "^2.6.3",
    "typedoc": "^0.28.19",
    "typedoc-github-theme": "^0.4.0",
    "typescript": "^5.5.3"
  }
}
