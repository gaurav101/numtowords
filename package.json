{
  "name": "@gks101/numtowords",
  "version": "1.0.2",
  "description": "Convert numbers to words in multiple languages and numeral systems (English, Indian, etc.)",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs && tsc --target ES2020 --module ES2020 --downlevelIteration --skipLibCheck --noEmitOnError false --outDir dist/locales --rootDir src src/locales/*.ts",
    "test": "jest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "number-to-words",
    "multilingual",
    "indian-numbering",
    "english",
    "hindi",
    "number-converter",
    "number-to-word-converter",
    "i18n"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.18.0",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.6.3",
    "typescript": "^5.5.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.2.2"
  }
}
